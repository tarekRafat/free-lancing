{
  "compilerOptions": {
    "target": "es5",
    "module": "es6",
    "allowJs": true,
    "outDir": "js",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jquery"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
